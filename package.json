{
  "name": "nuxters",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "lint": "eslint .",
    "collect:contributors": "tsx scripts/collect-contributors.ts",
    "postinstall": "nuxt prepare",
    "test:browser": "playwright test test/browser",
    "test:browser:update": "docker run --rm --network host -v $(pwd):/work/ -v /tmp/playwright-node-modules:/work/node_modules -w /work/ -it mcr.microsoft.com/playwright:v1.55.1-noble bash -c 'corepack enable && pnpm i && pnpm playwright test test/browser --update-snapshots'",
    "test:nuxt": "vitest --project nuxt",
    "test:types": "vue-tsc -b --noEmit",
    "test:unit": "vitest --project unit"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.104",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.80",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.7.0",
    "@nuxthub/core": "^0.10.7",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@takumi-rs/core": "^1.1.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.4",
    "nuxt-og-image": "^6.4.8",
    "octokit": "^5.0.5",
    "ofetch": "^1.5.1",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.4",
    "ufo": "^1.6.3",
    "uncrypto": "^0.1.3",
    "unstorage": "^1.17.5",
    "vue": "^3.5.33",
    "vue-confetti-explosion": "^1.0.2"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
